# Database
POSTGRES_USER=contract_ai
POSTGRES_PASSWORD=local_dev_password
POSTGRES_DB=contract_ai
DATABASE_URL=postgresql+asyncpg://contract_ai:local_dev_password@postgres:5432/contract_ai

# Embedding (fixed — do not change after init, requires full re-embed)
EMBED_MODEL=text-embedding-3-small
EMBED_DIMENSION=1536
EMBED_API_KEY=sk-...

# LLM (initial — can be changed via admin UI later)
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-...

# Admin
ADMIN_KEY_HASH=  # SHA-256 hash of admin key
SESSION_SECRET=  # Random 32-byte hex for cookie signing

# App
CORS_ORIGINS=http://localhost:3000
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
